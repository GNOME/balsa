#: org.desktop.Balsa.desktop.in.in:2 org.desktop.Balsa.metainfo.xml.in:6 balsa-mailto-handler.desktop.in.in:2 libbalsa/system-tray.c:102
msgid "Balsa"
msgstr "Балса"

#: org.desktop.Balsa.desktop.in.in:3 org.desktop.Balsa.metainfo.xml.in:7 balsa-mailto-handler.desktop.in.in:3
msgid "Email utility"
msgstr "Алат за е-пошту"

#: org.desktop.Balsa.desktop.in.in:4 balsa-mailto-handler.desktop.in.in:4
msgid "Mail Client"
msgstr "Програм за е-пошту"

#: org.desktop.Balsa.desktop.in.in:15
msgid "Mail;E-mail;Email;IMAP"
msgstr "Mail;E-mail;Email;IMAP;Пошта;Е-пошта;Емаил;ИМАП"

#: org.desktop.Balsa.metainfo.xml.in:11
msgid "Balsa is a graphical mail client. While it is in active development, Balsa has many features such as:"
msgstr "Балса је графички клијент за пошту. Иако је у активном развоју, Балса има много функција као што су:"

#: org.desktop.Balsa.metainfo.xml.in:14
msgid "IMAP and POP3 support;"
msgstr "ИМАП и ПОП3 подршка;"

#: org.desktop.Balsa.metainfo.xml.in:15
msgid "sendmail or direct SMTP support;"
msgstr "„sendmail“ или директна СМТП подршка;"

#: org.desktop.Balsa.metainfo.xml.in:16
msgid "end-to-end encryption using GnuPG or S/MIME;"
msgstr "шифровање од краја до краја користећи ГнуПГ или С/МИМЕ;"

#: org.desktop.Balsa.metainfo.xml.in:17
msgid "multi-threaded retrieval and sending of messages;"
msgstr "вишенитно преузимање и слање порука;"

#: org.desktop.Balsa.metainfo.xml.in:18
msgid "support for all configurations of local mail folders;"
msgstr "подршка за сва подешавања месних фасцикли поште;"

#: org.desktop.Balsa.metainfo.xml.in:19
msgid "automatic mail checking;"
msgstr "аутоматска провера поште;"

#: org.desktop.Balsa.metainfo.xml.in:20
msgid "mail printing;"
msgstr "штампање поште;"

#: org.desktop.Balsa.metainfo.xml.in:21
msgid "inline attachment viewing;"
msgstr "преглед прилога на мрежи;"

#: org.desktop.Balsa.metainfo.xml.in:23
msgid "and the proverbial much, much more."
msgstr "и још много, много тога."

#: org.desktop.Balsa.metainfo.xml.in:27
msgid "Main Window"
msgstr "Главни прозор"

#: org.desktop.Balsa.metainfo.xml.in:31
msgid "Filter Edition"
msgstr "Уређивање филтера"

